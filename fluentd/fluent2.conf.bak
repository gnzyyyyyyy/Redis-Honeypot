<source>
  @type tail
  path /var/log/honeypot/redis.log
  pos_file /var/log/honeypot/redis.pos
  tag redis.honeypot
  format json
  read_from_head true
</source>

<match redis.honeypot>
  @type elasticsearch
  host elasticsearch
  port 9200
  scheme http
  logstash_format false
  logstash_prefix redis-honeypot
  include_tag_key true
  reconnect_on_error true
  verify_es_version_at_startup false
</match>
