<source>
  @type tail
  path /var/log/honeypot/redis.log
  pos_file /var/log/honeypot/redis.pos
  tag redis.honeypot
  read_from_head true

  <parse>
    @type json
    time_key time
    time_format %Y-%m-%dT%H:%M:%S.%NZ
    keep_time_key true
  </parse>
</source>

<match redis.honeypot>
  @type elasticsearch
  host elasticsearch
  port 9200
  scheme http
  index_name redis-honeypot
  logstash_format false
  include_tag_key false
  reconnect_on_error true
  verify_es_version_at_startup false
</match>
